DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"

# ─── Multi-Zone reverse proxy (only on the deploy that runs behind the tools hub) ─
# Leave ALL of these UNSET for the standalone root deployment — the app then builds
# and runs exactly as before. Set them only on the subpath (proxied) deployment.
#
#   NEXT_PUBLIC_BASE_PATH   = "/super-analytics"   # activates basePath + disables the embed gate
#   NEXTAUTH_URL            = "https://tools-staging.vercel.app/super-analytics"   # incl. the basePath
#   SHARE_BASE_URL          = "https://tools-staging.vercel.app/super-analytics"   # report share links
#   SERVER_ACTIONS_ALLOWED_ORIGINS = "abc123.vercel.app"   # optional: extra gateway/preview host(s), comma-sep
#
# Production values (after promotion):
#   NEXTAUTH_URL   = "https://tools.digitalleapmarketing.com/super-analytics"
#   SHARE_BASE_URL = "https://tools.digitalleapmarketing.com/super-analytics"
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
CRON_SECRET=""

# DataForSEO (optional) — used for live keyword rank tracking via SERP API.
# When set, the daily cron pulls today's organic rank for every tracked keyword
# and stores it in KeywordRanking. Without these, the cron falls back to GSC,
# which only reports keywords that already drove impressions.
# Charged per SERP call (Regular ~$0.0006). Sign up at https://dataforseo.com.
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
